# Copy to .env.local and fill in your values

# Database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Payments — Hubtel (primary) + Moolre (optional fallback)
HUBTEL_CLIENT_ID=YOUR_HUBTEL_CLIENT_ID
HUBTEL_CLIENT_SECRET=YOUR_HUBTEL_CLIENT_SECRET
HUBTEL_MERCHANT_ACCOUNT_NUMBER=YOUR_HUBTEL_MERCHANT_ACCOUNT_NUMBER
HUBTEL_ONLINE_CHECKOUT_URL=https://payproxyapi.hubtel.com/items/initiate
HUBTEL_STATUS_URL=https://api-txnstatus.hubtel.com/transactions

MOOLRE_API_KEY=YOUR_PAYMENT_API_KEY
MOOLRE_API_USER=YOUR_PAYMENT_API_USER
MOOLRE_API_PUBKEY=YOUR_PAYMENT_PUBLIC_KEY
MOOLRE_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
MOOLRE_MERCHANT_EMAIL=your@email.com
HUBTEL_MERCHANT_EMAIL=your@email.com
MOOLRE_CALLBACK_SECRET=YOUR_CALLBACK_SECRET
MOOLRE_SMS_API_KEY=YOUR_SMS_API_KEY
MOOLRE_SMS_SENDER_ID=YOUR_APPROVED_SENDER_ID

# Email (Resend — domain must be verified at https://resend.com/domains)
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=Vee Care Hera <info@veecare.shop>
ADMIN_EMAIL=admin@yourdomain.com,backup@yourdomain.com
# All comma-separated ADMIN_EMAIL addresses receive order, contact, support, and return alerts.
# Optional alias for EMAIL_FROM:
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Optional
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
NEXT_PUBLIC_GA_MEASUREMENT_ID=YOUR_GA4_MEASUREMENT_ID
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
