# Copy to .env.local and fill in your values

# Database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Payments (Moolre / Paystack — use your provider keys)
MOOLRE_API_KEY=YOUR_PAYMENT_API_KEY
MOOLRE_API_USER=YOUR_PAYMENT_API_USER
MOOLRE_API_PUBKEY=YOUR_PAYMENT_PUBLIC_KEY
MOOLRE_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
MOOLRE_MERCHANT_EMAIL=your@email.com
MOOLRE_CALLBACK_SECRET=YOUR_CALLBACK_SECRET
MOOLRE_SMS_API_KEY=YOUR_SMS_API_KEY

# Email
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=your@email.com
EMAIL_FROM=YOUR_SENDER_NAME <noreply@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Optional
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
NEXT_PUBLIC_GA_MEASUREMENT_ID=YOUR_GA4_MEASUREMENT_ID
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
