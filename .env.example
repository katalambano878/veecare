# Copy to .env.local and fill in your values

# Database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Payments — Moolre (primary) + Paystack (card & Mobile Money)
MOOLRE_API_KEY=YOUR_PAYMENT_API_KEY
MOOLRE_API_USER=YOUR_PAYMENT_API_USER
MOOLRE_API_PUBKEY=YOUR_PAYMENT_PUBLIC_KEY
MOOLRE_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
MOOLRE_MERCHANT_EMAIL=your@email.com
MOOLRE_CALLBACK_SECRET=YOUR_CALLBACK_SECRET

# Paystack — get keys at https://dashboard.paystack.com/#/settings/developers
# Set the webhook URL there to: https://yourdomain.com/api/payment/paystack/callback
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_MERCHANT_EMAIL=your@email.com
# Optional (defaults to GHS)
# PAYSTACK_CURRENCY=GHS
MOOLRE_SMS_API_KEY=YOUR_SMS_API_KEY
MOOLRE_SMS_SENDER_ID=YOUR_APPROVED_SENDER_ID

# Email (Resend — domain must be verified at https://resend.com/domains)
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=Vee Care Hera <info@veecare.shop>
ADMIN_EMAIL=admin@yourdomain.com,backup@yourdomain.com
# All comma-separated ADMIN_EMAIL addresses receive order, contact, support, and return alerts.
# Optional alias for EMAIL_FROM:
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
# Optional — prefix for auto-generated product SKUs (default: VEECARE)
# PRODUCT_SKU_PREFIX=VEECARE

# Optional
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
NEXT_PUBLIC_GA_MEASUREMENT_ID=YOUR_GA4_MEASUREMENT_ID
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
